# ── App ─────────────────────────────────────────────────────────────
APP_ENV=development                # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-64-random-chars
APP_CORS_ORIGINS=["http://localhost:3000"]

# ── Database (PostgreSQL) ───────────────────────────────────────────
DB__HOST=localhost
DB__PORT=5433   # 5433: docker-mapped port (5432 on this host is a local Homebrew postgres)
DB__USER=stocks
DB__PASSWORD=stocks
DB__NAME=stocks
DB__POOL_SIZE=10

# ── Redis ───────────────────────────────────────────────────────────
REDIS__URL=redis://localhost:6379/0

# ── Qdrant (vector DB) ──────────────────────────────────────────────
QDRANT__URL=http://localhost:6333
QDRANT__API_KEY=

# ── Auth ────────────────────────────────────────────────────────────
AUTH__ACCESS_TOKEN_TTL_MINUTES=15
AUTH__REFRESH_TOKEN_TTL_DAYS=30
AUTH__GOOGLE_CLIENT_ID=
AUTH__GOOGLE_CLIENT_SECRET=
AUTH__GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── AI provider selection (never hardcoded in code) ────────────────
AI__PROVIDER=ollama                # gemini|claude|openai|groq|openrouter|ollama|deepseek|mistral
AI__FALLBACK_PROVIDERS=[]          # e.g. ["groq","openrouter"]
AI__AGENT_OVERRIDES={}             # e.g. {"research":"claude","news_intelligence":"groq"}

# Provider credentials (fill only the ones you use)
AI__GEMINI_API_KEY=
AI__ANTHROPIC_API_KEY=
AI__OPENAI_API_KEY=
AI__GROQ_API_KEY=
AI__OPENROUTER_API_KEY=
AI__DEEPSEEK_API_KEY=
AI__MISTRAL_API_KEY=
AI__OLLAMA_BASE_URL=http://localhost:11434
AI__OLLAMA_MODEL=                  # empty = adapter default ("llama3.1"); set to whatever you've pulled, e.g. llama3.2:3b

# ── Market data sources (M6) ────────────────────────────────────────
# Primary quotes/history/company-info/fundamentals vendor — never hardcoded,
# same "provider" convention as AI__PROVIDER.
#   finnhub       — real REST API, needs an API key; NSE/BSE (India) is
#                   paid-plan-only even with a key.
#   yahoo_finance — unofficial/undocumented, no key; the only free option
#                   for real NSE/BSE quotes and history found so far.
MARKET__PROVIDER=finnhub
MARKET__ALPHA_VANTAGE_API_KEY=
MARKET__FINNHUB_API_KEY=
# Optional: news comes from marketaux instead of the primary vendor's own
# news endpoint when this is set — useful since Finnhub has no Indian
# coverage at all, and marketaux's plain keyword search works for both US
# and Indian names. Free tier: 100 requests/day.
MARKET__MARKETAUX_API_KEY=
MARKET__MARKETAUX_MIN_INTERVAL_HOURS=4
# Recommended: restricts scheduled agents to exactly this universe instead of
# every row in `companies`, so a shared dev database (test fixtures, manual
# lookups) can never derail the real pipeline or burn through vendor quotas.
# Leave empty to fall back to "every active company in the database". NSE
# symbols use Yahoo's ".NS" suffix (e.g. "RELIANCE.NS") when using yahoo_finance.
MARKET__TRACKED_SYMBOLS=["AAPL","MSFT","GOOGL"]

# ── Rate limiting (M30) ─────────────────────────────────────────────
# Per-IP fixed window, backed by Redis. Set to false for local dev/test.
RATE_LIMIT__ENABLED=true
RATE_LIMIT__DEFAULT_PER_MINUTE=120
RATE_LIMIT__AUTH_PER_MINUTE=10
